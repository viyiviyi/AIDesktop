{
  "id": "desktop-assistant",
  "name": "桌面助手",
  "description": "内置桌面助手，提供基础对话和系统操作功能。可以调用其他应用和服务来完成任务。",
  "source": "marketplace",
  "type": "desktop",
  "icon": "/public_icons/assistant.svg",
  "models": [
    {
      "provider": "deepseek",
      "model": "deepseek-v4-flash",
      "priority": 1,
      "maxTokens": 4096,
      "supports": [
        "text"
      ],
      "params": {}
    }
  ],
  "supportedInputs": [
    "text",
    "image",
    "audio"
  ],
  "inputDescription": "支持文本、图片、语音输入",
  "outputDescription": "返回文本、图片、语音回复",
  "visibleApps": [
    "settings",
    "app-builder",
    "file-manager",
    "trash"
  ],
  "visibleServices": [
    "clipboard",
    "notification"
  ],
  "tools": [
    "mcp.filesystem",
    "mcp.window",
    "mcp.settings",
    "mcp.agent",
    "mcp.browser"
  ],
  "headerParams": [],
  "bodyParams": [],
  "enabled": true,
  "backgroundImage": ""
}